############################################
# Copy to config.env and fill in values.
# config.env is gitignored.
############################################

AI_CLIENT="openai"
WEB_SEARCH_CLIENT="openai"

OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o-mini"
OPENAI_BASE_URL="https://api.openai.com/v1"

GROQ_API_KEY=
GROQ_MODEL=llama-3.1-70b-versatile
GROQ_BASE_URL=https://api.groq.com/openai/v1

AZURE_OPENAI_API_KEY=""
AZURE_OPENAI_ENDPOINT=""
AZURE_OPENAI_DEPLOYMENT=""
AZURE_OPENAI_API_VERSION="2025-04-01-preview"

ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514

APIFY_API_TOKEN=""
APIFY_ACTOR_ID="supreme_coder/linkedin-profile-scraper"
APIFY_DATASET_CACHE_FILE=apify_dataset_cache.json

AI_CLIENT_TIMEOUT_SEC=60
AI_CLIENT_MAX_RETRIES=2

# LangSmith (optional)
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=linkedin-agent

EXPORT_LANGGRAPH_VIS="1"

MARKET_SIGNALS_ENABLE=false
MARKET_SIGNALS_PROVIDER=links
MARKET_VECTOR_STORE_PATH="Data/market_vectors.jsonl"
MARKET_EMBED_MODEL="text-embedding-3-small"
MARKET_FETCH_ENABLE=false

FRONTEND_ORIGIN=""
MCP_API_KEY=""
API_KEY=""
