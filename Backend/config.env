############################################
# AI Provider Selection
############################################
# Supported: openai | groq | azure | anthropic
AI_CLIENT="openai"

# Optional: provider used for web-search node.
# If empty, code falls back to AI_CLIENT.
WEB_SEARCH_CLIENT="openai"

############################################
# OpenAI
############################################
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o-mini"
# Optional custom OpenAI-compatible endpoint
OPENAI_BASE_URL="https://api.openai.com/v1"

############################################
# Groq (OpenAI-compatible)
############################################
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-70b-versatile
# Optional custom Groq-compatible endpoint
GROQ_BASE_URL=https://api.groq.com/openai/v1

############################################
# Azure OpenAI
############################################
AZURE_OPENAI_API_KEY=""
AZURE_OPENAI_ENDPOINT=""
AZURE_OPENAI_DEPLOYMENT="gpt-5-chat"
AZURE_OPENAI_API_VERSION="2025-04-01-preview"

############################################
# Anthropic
############################################
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514

############################################
# LinkedIn Fetch
############################################
# Primary LinkedIn data source (Apify)
APIFY_API_TOKEN=""
APIFY_ACTOR_ID="supreme_coder/linkedin-profile-scraper"
# Local cache map for profile->dataset_id reuse
APIFY_DATASET_CACHE_FILE=apify_dataset_cache.json

############################################
# Client Runtime Tuning
############################################
AI_CLIENT_TIMEOUT_SEC=60
AI_CLIENT_MAX_RETRIES=2


EXPORT_LANGGRAPH_VIS="1"

############################################
# Market Signals Enrichment (Job Recommendations)
############################################
# Toggle market trend/source enrichment for job_recommendations
# true = enable enrichment; false = disable
MARKET_SIGNALS_ENABLE=false
# Provider hint (reserved for future MCP/web integrations). Keep 'links' to use curated discovery links.
MARKET_SIGNALS_PROVIDER=links

############################################
# Market Signals Vector Store / Embeddings
############################################
# Local file path for simple JSONL vector store
MARKET_VECTOR_STORE_PATH="Data/market_vectors.jsonl"
# Embedding model for role market chunks (OpenAI model name)
MARKET_EMBED_MODEL="text-embedding-3-small"
# Optional: allow HTTP fetch of sources (experimental, may be blocked by sites)
MARKET_FETCH_ENABLE=false

############################################
# Frontend + Auth
############################################
# Optional: set your frontend URL to tighten CORS. Leave empty to allow all.
FRONTEND_ORIGIN=""
# Set one of the following to secure /agent/* and /mcp/* endpoints:
# Prefer MCP_API_KEY; API_KEY is a fallback for compatibility.
MCP_API_KEY=""
# API_KEY=""
